{
  "name": "skin-gallery",
  "version": "1.1.1",
  "description": "Minecraft skin gallery — 3Dビューア・整理・ランチャー連携",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "test:scan": "node electron/skins.js .",
    "test:launcher": "node electron/launcher.js --list"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.skingallery.app",
    "productName": "SkinGallery",
    "files": [
      "electron/**/*",
      "index.html",
      "skinview3d.bundle.js",
      "package.json"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    },
    "portable": {
      "artifactName": "SkinGallery-${version}-portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "SkinGallery-${version}-setup.exe"
    }
  }
}
